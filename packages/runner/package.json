{
  "name": "@agent-badge/runner",
  "devDependencies": {
    "@types/bun": "latest",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "private": true,
  "scripts": {
    "build": "NODE_ENV=production bun build frontend/index.html --outdir frontend/dist --minify",
    "dev": "bun --hot src/server.ts",
    "start": "bun run build && bun run src/server.ts"
  },
  "dependencies": {
    "browser-use-sdk": "^3.1.0",
    "hono": "^4.12.3"
  }
}
